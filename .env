# ── LLM Provider (optional) ─────────────────────
# 明确指定使用 OpenAI 兼容接口
RESEARCH_AGENT_LLM_PROVIDER=openai

# ── SiliconFlow (硅基流动) 配置 ─────────────────
# 使用您从硅基流动官网 (https://cloud.siliconflow.cn) 获取的API密钥
OPENAI_API_KEY=sk-qkkymbvxgfgpyduuzrsfnnjeebxrrecwkehjuckzruqzqhok
# 硅基流动的API端点 (固定值)
OPENAI_BASE_URL=https://api.siliconflow.cn/v1
# 选择模型，从以下推荐的模型中选择一个，或使用您偏好的其他模型
OPENAI_MODEL=deepseek-ai/DeepSeek-V3.2

# ── Gemini (optional) ───────────────────────────
# 确保以下行被注释（开头有#），因为我们不再使用Gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash

# ── OpenAI (optional) ───────────────────────────
# 原始OpenAI配置，如需使用官方OpenAI可取消注释并填写
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# ── Anthropic (optional) ────────────────────────
# 保持注释
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ── 以下可选配置通常可保持默认 ───────────────────
# GITHUB_TOKEN=
# DATABASE_URL=sqlite:///incite_research.db
# RESEARCH_AGENT_CACHE_DIR=.research_agent_cache
RESEARCH_AGENT_PAPER_MIN=25
RESEARCH_AGENT_PAPER_LIMIT=100
# RESEARCH_AGENT_AUTO_READ_PDF=1
# RESEARCH_AGENT_AUTO_READ_PDF_MAX=4
# RESEARCH_AGENT_PDF_MAX_PAGES=12
# RESEARCH_AGENT_PDF_MAX_CHARS=30000